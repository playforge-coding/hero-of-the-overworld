    // ------------------------------------------------------------------------
    // Cutscenes. A `Say` step shows a dialogue line (with an optional portrait
    // = a character/enemy id); a `Recruit` step adds a character to the party.
    // Referenced by levels via intro_cutscene / clear_cutscene.
    // ------------------------------------------------------------------------
    cutscenes: [
        CutsceneDef(
            id: "greenwood_intro",
            steps: [
                Say(speaker: Some("ROLAND"), portrait: Some("swordsman"),
                    text: "THE GREENWOOD SWARMS WITH SLIMES - AND A DEMON LURKS DEEP WITHIN."),
            ],
        ),
        CutsceneDef(
            id: "mage_joins",
            steps: [
                Say(speaker: Some("???"), portrait: Some("mage"),
                    text: "HOLD! YOU CLEARED THE GREENWOOD ALONE?"),
                Say(speaker: Some("ELARA"), portrait: Some("mage"),
                    text: "I AM ELARA, A WANDERING MAGE. YOUR CAUSE IS MINE NOW."),
                Recruit(character: "mage"),
                Say(speaker: Some("ROLAND"), portrait: Some("swordsman"),
                    text: "GLAD TO HAVE YOUR FIRE AT MY BACK, ELARA."),
            ],
        ),
        CutsceneDef(
            id: "travellersend_intro",
            steps: [
                Say(speaker: Some("ROLAND"), portrait: Some("swordsman"),
                    text: "TRAVELLER'S END - THE LAST MOUNTAIN PASS BEFORE THE DEMON FORTRESS."),
                Say(speaker: Some("ELARA"), portrait: Some("mage"),
                    text: "CRABS AND SKELETONS ARE THE LEAST OF IT. THE DARK KNIGHTS RIDE THESE HEIGHTS."),
                Say(speaker: Some("ROLAND"), portrait: Some("swordsman"),
                    text: "THEN WE CLIMB - AND WE DO NOT STOP UNTIL WE REACH THE SUMMIT."),
            ],
        ),
        CutsceneDef(
            id: "gareth_joins",
            steps: [
                Say(speaker: Some("???"), portrait: Some("hermit"),
                    text: "STILL BREATHING, AFTER ALL THAT? NO ONE CLEARS THIS PASS. NO ONE."),
                Say(speaker: Some("ROLAND"), portrait: Some("swordsman"),
                    text: "WHO ARE YOU? YOU MOVE LIKE NO HERMIT I EVER MET."),
                Say(speaker: Some("GARETH"), portrait: Some("hermit"),
                    text: "GARETH. THE KING'S SCOUT, ONCE. I SAW THE ADVISOR MEET WITH DEMONS IN THE DARK."),
                Say(speaker: Some("GARETH"), portrait: Some("hermit"),
                    text: "I WARNED THE AUTHORITIES. THEY BRANDED ME THE TRAITOR AND HUNTED ME. SO I RAN - HERE, TO TRAVELLER'S END."),
                Say(speaker: Some("ELARA"), portrait: Some("mage"),
                    text: "THEN YOU KNEW THE TRUTH BEFORE ANY OF US. WE MARCH ON THE ADVISOR NOW - COME WITH US."),
                Say(speaker: Some("GARETH"), portrait: Some("hermit"),
                    text: "I HAVE WAITED YEARS FOR SOMEONE TO SAY THAT. MY BLADE IS YOURS - AND IT IS FAST."),
                Recruit(character: "hermit"),
                Say(speaker: Some("ROLAND"), portrait: Some("swordsman"),
                    text: "THEN LEAD ON, SCOUT. NO ONE KNOWS THE ROAD TO THE FORTRESS BETTER THAN YOU."),
            ],
        ),
        // Plays once the DEMON FORTRESS is cleared (its `clear_cutscene`): the
        // dragon falls, the advisor's gate tears open, and the party steps through
        // into the UNDERWORLD. Afterwards the CHARRED DEPTHS stands unlocked on the
        // world map, so there is no need to return to the fortress to descend.
        CutsceneDef(
            id: "underworld_portal",
            steps: [
                Say(speaker: Some("ROLAND"), portrait: Some("swordsman"),
                    text: "THE DRAGON FALLS - BUT THE AIR STILL BURNS. WHAT IS THAT TEAR IN THE DARK?"),
                Say(speaker: Some("GARETH"), portrait: Some("hermit"),
                    text: "THE GATE. THIS IS WHERE THE ADVISOR THREW THE WORLD OPEN AND LET THE HORDE POUR UP."),
                Say(speaker: Some("ELARA"), portrait: Some("mage"),
                    text: "IT LEADS DOWN - INTO THE UNDERWORLD ITSELF. WHERE THE PRISONERS WERE DRAGGED. WHERE THE ROT BEGINS."),
                Say(speaker: Some("ROLAND"), portrait: Some("swordsman"),
                    text: "THEN THAT IS WHERE WE FINISH IT. INTO THE PORTAL - TOGETHER."),
                Say(speaker: None, portrait: None,
                    text: "THE PORTAL FLARES AND SWALLOWS THE PARTY - AND SPITS THEM OUT ONTO CHARRED STONE, DEEP BELOW THE WORLD."),
            ],
        ),
        // Plays on first entry to the CHARRED DEPTHS (its `intro_cutscene`).
        CutsceneDef(
            id: "charreddepths_intro",
            steps: [
                Say(speaker: Some("ROLAND"), portrait: Some("swordsman"),
                    text: "SO THIS IS THE UNDERWORLD. CHARRED STONE AS FAR AS THE TORCHLIGHT REACHES."),
                Say(speaker: Some("ELARA"), portrait: Some("mage"),
                    text: "THE CHARRED DEPTHS. THE PRISONERS WERE CAST DOWN HERE - AND THE DARK REMADE THEM FAST."),
                Say(speaker: Some("GARETH"), portrait: Some("hermit"),
                    text: "GOBLINS FROM THE ONES IT BROKE AND LOOSED. ORCS FROM THE ONES IT TWISTED WHOLE. WATCH THE ARCHERS - THEY STRIKE FROM RANGE."),
                Say(speaker: Some("ROLAND"), portrait: Some("swordsman"),
                    text: "THEY WERE OUR OWN, ONCE. WE END WHAT WAS DONE TO THEM - AND WHOEVER ORDERED IT."),
            ],
        ),
    ],
)
