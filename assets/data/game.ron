            ],
        ),
        // CHARRED DEPTHS — the first level of the UNDERWORLD, unlocked once the
        // DEMON FORTRESS falls (the portal cutscene draws the party down here).
        // A long warren of scorched flagstone that winds ever deeper: goblin packs
        // screen the upper halls, orc brutes wall the middle chambers two and three
        // abreast, and demon-led warbands hold the depths — culminating in the deep
        // hall's guardian. Charred-stone floor, dark ramparts. The toughest descent
        // in the game, mirroring the escalating climb of TRAVELLER'S END.
        LevelDef(
            id: "charreddepths", name: "CHARRED DEPTHS",
            node: (6, 2),
            start_screen: 0, start: (3, 5),
            ground: Some("charred_stone"),
            wall: Some("dark_wall"),
            intro_cutscene: Some("charreddepths_intro"),
            screens: [
