    // ------------------------------------------------------------------------
    // Cutscenes. A `Say` step shows a dialogue line (with an optional portrait
    // = a character/enemy id); a `Recruit` step adds a character to the party.
    // Referenced by levels via intro_cutscene / clear_cutscene.
    // ------------------------------------------------------------------------
    cutscenes: [
        CutsceneDef(
            id: "greenwood_intro",
            steps: [
                Say(speaker: Some("ROLAND"), portrait: Some("swordsman"),
                    text: "THE GREENWOOD SWARMS WITH SLIMES - AND A DEMON LURKS DEEP WITHIN."),
