// ============================================================================
// Hero of the Overworld — game data
// ----------------------------------------------------------------------------
// This RON file is the whole content database. To add a new party member or
// enemy, add an entry here (and register its texture key in src/data.rs).
// No engine/battle code needs to change.
//
// Sprite sheets are 16x16 grids. Animation clips select a `row` and a run of
// `frames` starting at `first_col`, played at `fps`.
//   swordsman.png : 5 cols x 12 rows. rows 0-3 = walk down/up/right/left,
//                   rows 4-7 = attack down/up/right/left.
//   mage.png      : 6 cols x 8 rows. rows 0-3 = walk down/up/right/left
//                   (4 frames), rows 4-7 = cast down/up/LEFT/RIGHT (5 frames;
//                   note the cast rows swap left/right vs. the walk rows).
//   demon.png     : 6 cols x 8 rows.
// ============================================================================
GameData(
    starting_party: ["swordsman"],

    characters: [
        CharacterDef(
            id: "swordsman",
            name: "ROLAND",
            stats: Stats(max_hp: 120, max_mp: 24, attack: 22, defense: 14, magic: 10, speed: 12),
            sprite: BattlerSprite(
                texture: "swordsman",
                frame_w: 16, frame_h: 16,
                draw_w: 48.0, draw_h: 48.0,
                faces_left: false,
                // "walk right" row read as a ready/idle march.
                idle:   AnimClip(row: 2, first_col: 0, frames: 4, fps: 5.0),
                // "attack right" row.
                attack: AnimClip(row: 6, first_col: 0, frames: 4, fps: 14.0),
            ),
            // Overworld walk: rows 0-3 are walk down/up/right/left (4 frames).
            overworld: Some(OverworldWalk(
                texture: "swordsman",
                frame_w: 16, frame_h: 16,
                draw_w: 20.0, draw_h: 20.0,
                row_down: 0, row_up: 1, row_right: 2, row_left: 3,
                frames: 4, fps: 8.0,
            )),
            skills: ["power_strike"],
            // ROLAND masters his sweeping WHIRLWIND a few fights in, then his
            // devastating SUNDER as his final, most powerful move.
            learnset: [
                LearnedSkill(level: 3, skill: "whirlwind"),
                LearnedSkill(level: 7, skill: "sunder"),
            ],
            weapon: Some("iron_sword"),
            armor: Some("leather_armor"),
        ),
        // Joins the party via a cutscene after GREENWOOD is cleared (she is not
        // in `starting_party`). Has her own purple mage sheet (mage.png).
        CharacterDef(
            id: "mage",
            name: "ELARA",
            stats: Stats(max_hp: 78, max_mp: 60, attack: 10, defense: 9, magic: 26, speed: 13),
            sprite: BattlerSprite(
                texture: "mage",
                frame_w: 16, frame_h: 16,
                draw_w: 48.0, draw_h: 48.0,
                faces_left: false,
                // Walk-right row read as idle; cast-right row (7) when acting.
                idle:   AnimClip(row: 2, first_col: 0, frames: 4, fps: 5.0),
                attack: AnimClip(row: 7, first_col: 0, frames: 5, fps: 14.0),
            ),
            // Overworld walk: rows 0-3 are walk down/up/right/left (4 frames).
            overworld: Some(OverworldWalk(
                texture: "mage",
                frame_w: 16, frame_h: 16,
                draw_w: 20.0, draw_h: 20.0,
                row_down: 0, row_up: 1, row_right: 2, row_left: 3,
                frames: 4, fps: 8.0,
            )),
            skills: ["firebolt"],
            // ELARA's chilling FROST comes with a little more study, and she alone
            // masters the potent healing of MEND as her final move.
            learnset: [
                LearnedSkill(level: 4, skill: "frost"),
                LearnedSkill(level: 7, skill: "mend"),
            ],
            armor: Some("travelers_robe"),
        ),
        // GARETH — a mountain hermit of TRAVELLER'S END and once the king's own
        // scout. He saw the advisor treat with demons, warned the authorities,
        // was branded a traitor for it, and fled to the heights. Joins after
        // TRAVELLER'S END is cleared (via the `gareth_joins` cutscene); not in
        // `starting_party`. Uses the `hermit` sheet: Roland's swordsman layout
        // with the four unused bottom rows trimmed (6x8 instead of 5x12), so
        // walk rows 0-3 run 5 frames and attack rows 4-7 run 6. He is the
        // FASTEST, nimblest hero — high speed, cheap darting strikes.
        CharacterDef(
            id: "hermit",
            name: "GARETH",
            stats: Stats(max_hp: 94, max_mp: 30, attack: 20, defense: 11, magic: 8, speed: 21),
            // A scout's reflexes: a far more forgiving timed-hit window than the
            // default (perfect 0.05 / good 0.13) — for both his strikes and his
            // blocks — so his GOOD/PERFECT taps are much easier to land.
            // Per-character; any hero can tune this.
            timing: Some(TimingWindow(perfect: 0.09, good: 0.20)),
            sprite: BattlerSprite(
                texture: "hermit",
                frame_w: 16, frame_h: 16,
                draw_w: 48.0, draw_h: 48.0,
                faces_left: false,
                // "walk right" row read as a ready/idle stance (5 frames).
                idle:   AnimClip(row: 2, first_col: 0, frames: 5, fps: 5.0),
                // "attack right" row (6 frames) — struck fast to read as nimble.
                attack: AnimClip(row: 6, first_col: 0, frames: 6, fps: 18.0),
            ),
            // Overworld walk: rows 0-3 are walk down/up/right/left (5 frames).
            overworld: Some(OverworldWalk(
                texture: "hermit",
                frame_w: 16, frame_h: 16,
                draw_w: 20.0, draw_h: 20.0,
                row_down: 0, row_up: 1, row_right: 2, row_left: 3,
                frames: 5, fps: 9.0,
            )),
            skills: ["quick_slash"],
            // GARETH's SWALLOW CUT — a scout's sweep — comes early; his lethal
            // FINAL CUT is his last, most powerful move. Recruited mid-game, the
            // learnset catches him up to everything his level grants on join.
            learnset: [
                LearnedSkill(level: 2, skill: "swallow_cut"),
                LearnedSkill(level: 7, skill: "final_cut"),
            ],
            weapon: Some("scouts_edge"),
            armor: Some("scouts_cloak"),
        ),
    ],

    enemies: [
        // Weak swarm fodder. Slimes come three at a time; individually harmless,
        // but a pack can whittle you down. slime.png is a 6x4 sheet: rows 0-3 are
        // the walk cycles (down/up/right/left); it has no separate attack rows, so
        // the "attack" clip just reuses the walk row played faster (a quick hop).
        EnemyDef(
            id: "slime",
            name: "SLIME",
            stats: Stats(max_hp: 22, max_mp: 0, attack: 8, defense: 4, magic: 0, speed: 8),
            sprite: BattlerSprite(
                texture: "slime",
                frame_w: 16, frame_h: 16,
                draw_w: 40.0, draw_h: 40.0,
                faces_left: false,
                idle:   AnimClip(row: 0, first_col: 0, frames: 4, fps: 4.0),
                attack: AnimClip(row: 0, first_col: 0, frames: 4, fps: 10.0),
            ),
            overworld: Some(OverworldWalk(
                texture: "slime",
                frame_w: 16, frame_h: 16,
                draw_w: 18.0, draw_h: 18.0,
                row_down: 0, row_up: 1, row_right: 2, row_left: 3,
                frames: 4, fps: 8.0,
            )),
            skills: [],
            ai: Basic,
            xp: 4,
            gold: 3,
            drops: [ItemDrop(item: "potion", chance: 0.25)],
        ),
        // The MIMIC — a chest that bites back, and a LATE-GAME ambush predator: it
        // lurks in the deep regions (TRAVELLER'S END, the DEMON FORTRESS, the
        // CHARRED DEPTHS) disguised as treasure, then springs when you draw near.
        // Powerful and tricky in a fight — it hurls FIREBALL, bites hard, and, its
        // signature, APES the party's last move: it takes on that hero's very shape
        // to cast a nerfed copy of it (see `mimicry`). Beating one is well paid: a
        // fat purse and generous drops. mimic.png is a 16x32 sheet — one column of
        // two 16x16 frames: row 0 the dormant disguise, row 1 the toothy lunge.
        EnemyDef(
            id: "mimic",
            name: "MIMIC",
            stats: Stats(max_hp: 132, max_mp: 40, attack: 26, defense: 14, magic: 24, speed: 14),
            sprite: BattlerSprite(
                texture: "mimic",
                frame_w: 16, frame_h: 16,
                draw_w: 46.0, draw_h: 46.0,
                faces_left: false,
                idle:   AnimClip(row: 0, first_col: 0, frames: 1, fps: 1.0),
                attack: AnimClip(row: 1, first_col: 0, frames: 1, fps: 1.0),
            ),
            // Its own moves: FIREBALL and a heavy bite (the AI's basic-attack
            // fallback). `Random` so it mixes the cast in with plain swings.
            skills: ["fireball"],
            ai: Random,
            xp: 55,
            gold: 80,
            drops: [
                ItemDrop(item: "hi_potion", chance: 0.5),
                ItemDrop(item: "ether",     chance: 0.4),
            ],
            // The signature trick: ape the party's last move at 65% power, wearing
            // that hero's shape as it strikes. The allow-list is the safe subset —
            // mid-power strikes and the party's area moves — deliberately leaving
            // out the big finishers (SUNDER, FINAL CUT) and MEND, so a mimic stays
            // dangerous without being able to parrot a nuke back at the party.
            mimicry: Some(MimicryDef(
                copyable: [
                    "power_strike", "whirlwind",   // ROLAND
                    "firebolt", "frost",           // ELARA
                    "quick_slash", "swallow_cut",  // GARETH
                ],
                power_pct: 65,
                chance: 0.5,
            )),
        ),
        // The demons are now the elite threat, held back in the DEMON FORTRESS (plus a
        // lone one guarding the end of GREENWOOD). FIREBALL leaves the target
        // BURNING for three rounds, so they punish a drawn-out fight.
        EnemyDef(
            id: "demon",
            name: "DEMON",
            stats: Stats(max_hp: 68, max_mp: 30, attack: 18, defense: 9, magic: 16, speed: 10),
            sprite: BattlerSprite(
                texture: "demon",
                frame_w: 16, frame_h: 16,
                draw_w: 56.0, draw_h: 56.0,
                faces_left: false,
                idle:   AnimClip(row: 0, first_col: 0, frames: 4, fps: 4.0),
                attack: AnimClip(row: 4, first_col: 0, frames: 4, fps: 10.0),
            ),
            // Overworld walk: rows 0-3 are walk down/up/right/left, 5 frames each
            // (the 6th column is empty). Attack poses live in rows 4-7.
            overworld: Some(OverworldWalk(
                texture: "demon",
                frame_w: 16, frame_h: 16,
                draw_w: 22.0, draw_h: 22.0,
                row_down: 0, row_up: 1, row_right: 2, row_left: 3,
                frames: 5, fps: 8.0,
            )),
            skills: ["fireball", "claw"],
            ai: Random,
            xp: 16,
            gold: 12,
            drops: [
                ItemDrop(item: "might_tonic", chance: 0.15),
                ItemDrop(item: "hi_potion",   chance: 0.10),
            ],
        ),
        // Stone sentinels of STONE PASS. They hit like a landslide (via the
        // STONE FISTS weapon) but are ponderously slow — last to act in battle
        // and easy to outrun on the map — and their crude swings miss often
        // (the weapon carries a big accuracy penalty). gargoyle.png shares the
        // demon's 6x8 layout: rows 0-3 walk, rows 4-7 attack.
        EnemyDef(
            id: "gargoyle",
            name: "GARGOYLE",
            stats: Stats(max_hp: 64, max_mp: 0, attack: 20, defense: 14, magic: 0, speed: 3),
            sprite: BattlerSprite(
                texture: "gargoyle",
                frame_w: 16, frame_h: 16,
                draw_w: 62.0, draw_h: 62.0,
                faces_left: false,
                idle:   AnimClip(row: 0, first_col: 0, frames: 4, fps: 3.0),
                attack: AnimClip(row: 4, first_col: 0, frames: 4, fps: 7.0),
            ),
            overworld: Some(OverworldWalk(
                texture: "gargoyle",
                frame_w: 16, frame_h: 16,
                draw_w: 24.0, draw_h: 24.0,
                row_down: 0, row_up: 1, row_right: 2, row_left: 3,
                frames: 5, fps: 5.0,
            )),
            skills: [],
            weapon: Some("stone_fists"),
            ai: Basic,
            xp: 18,
            gold: 14,
            // Lumbering: far slower than the player, so easy to dodge on the map.
            overworld_speed: Some(18.0),
            drops: [
                ItemDrop(item: "ether",       chance: 0.20),
                ItemDrop(item: "guard_salve", chance: 0.10),
            ],
        ),
        // The DRAGON: the boss guarding the depths of the DEMON FORTRESS. A huge
        // damage sponge with a party-wide FLAME BREATH (leaves everyone BURNING)
        // and a heavy single-target TAIL SWIPE. Its Random AI rotates skills by
        // HP. dragon.png is a 4x6 grid of 32x32 frames: rows 0-1 are front-facing
        // poses, rows 2-3 a side-on serpent; the overworld walk reads rows 0-3 as
        // down/up/right/left.
        EnemyDef(
            id: "dragon",
            name: "DRAGON",
            stats: Stats(max_hp: 340, max_mp: 80, attack: 26, defense: 17, magic: 24, speed: 11),
            sprite: BattlerSprite(
                texture: "dragon",
                frame_w: 32, frame_h: 32,
                draw_w: 96.0, draw_h: 96.0,
                faces_left: false,
                idle:   AnimClip(row: 0, first_col: 0, frames: 4, fps: 4.0),
                attack: AnimClip(row: 1, first_col: 0, frames: 4, fps: 10.0),
            ),
            overworld: Some(OverworldWalk(
                texture: "dragon",
                frame_w: 32, frame_h: 32,
                draw_w: 32.0, draw_h: 32.0,
                row_down: 0, row_up: 1, row_right: 2, row_left: 3,
                frames: 4, fps: 6.0,
            )),
            skills: ["flame_breath", "tail_swipe"],
            ai: Random,
            xp: 150,
            gold: 120,
            // Prowls its lair at a steady, menacing pace.
            overworld_speed: Some(26.0),
            // The hoard: a guaranteed hi-potion for felling the boss.
            drops: [ItemDrop(item: "hi_potion", chance: 1.0)],
        ),
        // ------ TRAVELLER'S END denizens ------------------------------------
        // Mountain crabs: skittering shell-backed fodder of the low slopes. Weak
        // and slow, but their hard shells (high defense) make them a chore to
        // crack. mountain_crab.png is a tiny 3x1 sheet: one front-facing row, so
        // the "attack" clip just replays the idle row a touch faster (a pinch).
        EnemyDef(
            id: "mountain_crab",
            name: "MOUNTAIN CRAB",
            stats: Stats(max_hp: 30, max_mp: 0, attack: 11, defense: 13, magic: 0, speed: 5),
            sprite: BattlerSprite(
                texture: "mountain_crab",
                frame_w: 16, frame_h: 16,
                draw_w: 38.0, draw_h: 38.0,
                faces_left: false,
                idle:   AnimClip(row: 0, first_col: 0, frames: 3, fps: 3.0),
                attack: AnimClip(row: 0, first_col: 0, frames: 3, fps: 8.0),
            ),
            // One-row sheet: every facing reads the same scuttle row.
            overworld: Some(OverworldWalk(
                texture: "mountain_crab",
                frame_w: 16, frame_h: 16,
                draw_w: 18.0, draw_h: 18.0,
                row_down: 0, row_up: 0, row_right: 0, row_left: 0,
                frames: 3, fps: 6.0,
            )),
            skills: [],
            ai: Basic,
            xp: 6,
            gold: 5,
            // Slow scuttle — easy to sidestep on the map.
            overworld_speed: Some(26.0),
            drops: [ItemDrop(item: "potion", chance: 0.20)],
        ),
        // Skeletons: restless undead of the high boneyards. Middling all-round
        // fighters that swing a REAP with their Random AI. skeleton.png shares
        // the swordsman's 5x12 layout exactly: rows 0-3 walk down/up/right/left,
        // rows 4-7 attack down/up/right/left — so, like ROLAND, the walk-right
        // row reads as idle and the attack-right row (6) is the battle swing.
        EnemyDef(
            id: "skeleton",
            name: "SKELETON",
            stats: Stats(max_hp: 46, max_mp: 8, attack: 17, defense: 7, magic: 2, speed: 12),
            sprite: BattlerSprite(
                texture: "skeleton",
                frame_w: 16, frame_h: 16,
                draw_w: 46.0, draw_h: 46.0,
                faces_left: false,
                idle:   AnimClip(row: 2, first_col: 0, frames: 4, fps: 5.0),
                attack: AnimClip(row: 6, first_col: 0, frames: 4, fps: 12.0),
            ),
            overworld: Some(OverworldWalk(
                texture: "skeleton",
                frame_w: 16, frame_h: 16,
                draw_w: 20.0, draw_h: 20.0,
                row_down: 0, row_up: 1, row_right: 2, row_left: 3,
                frames: 4, fps: 8.0,
            )),
            skills: ["reap"],
            ai: Random,
            xp: 15,
            gold: 11,
            drops: [ItemDrop(item: "bomb", chance: 0.22)],
        ),
        // Dark knights: the mounted lords of the pass and the elite threat of
        // TRAVELLER'S END. Fast (a charging warhorse acts early), heavily armed
        // with a CAVALRY LANCE, and able to LANCE CHARGE one hero or TRAMPLE the
        // whole party. dark_knight.png is a 4x12 sheet of 32x32 frames, three
        // rows per facing (walk, walk, attack): down 0-2, right 3-5, left 6-8,
        // up 9-11. The right-facing walk/attack rows serve as the battle idle/
        // swing (flipped to face the party, as with every enemy).
        EnemyDef(
            id: "dark_knight",
            name: "DARK KNIGHT",
            stats: Stats(max_hp: 100, max_mp: 16, attack: 22, defense: 16, magic: 4, speed: 15),
            sprite: BattlerSprite(
                texture: "dark_knight",
                frame_w: 32, frame_h: 32,
                draw_w: 78.0, draw_h: 78.0,
                faces_left: false,
                idle:   AnimClip(row: 3, first_col: 0, frames: 4, fps: 5.0),
                attack: AnimClip(row: 5, first_col: 0, frames: 4, fps: 10.0),
            ),
            overworld: Some(OverworldWalk(
                texture: "dark_knight",
                frame_w: 32, frame_h: 32,
                draw_w: 28.0, draw_h: 28.0,
                row_down: 0, row_up: 9, row_right: 3, row_left: 6,
                frames: 4, fps: 6.0,
            )),
            skills: ["lance_charge", "trample"],
            weapon: Some("cavalry_lance"),
            ai: Random,
            xp: 34,
            gold: 28,
            // Mounted and swift — nearly runs the player down; keep moving.
            overworld_speed: Some(48.0),
            drops: [
                ItemDrop(item: "hi_potion",   chance: 0.25),
                ItemDrop(item: "might_tonic", chance: 0.15),
            ],
        ),
        // ------ UNDERWORLD denizens: the GOBLIN and ORC families -------------
        // The war's prisoners, remade by the dark of the underworld. The GOBLINS
        // were indoctrinated into demon society and loosed to swarm the CHARRED
        // DEPTHS; the hulking ORCS are the same prisoners the change hit hardest.
        //
        // CLUB GOBLIN: the goblins' front line — small, quick, and numerous, they
        // rush in and hammer with a crude CLUB SMASH. Individually weak, but they
        // come in packs (and often with an archer covering them). All three new
        // sheets share the demon's layout: walk rows 0-3 (down/up/right/left),
        // attack rows 4-7 (down/up/right/left).
        EnemyDef(
            id: "club_goblin",
            name: "CLUB GOBLIN",
            stats: Stats(max_hp: 58, max_mp: 0, attack: 22, defense: 11, magic: 0, speed: 14),
            sprite: BattlerSprite(
                texture: "club_goblin",
                frame_w: 16, frame_h: 16,
                draw_w: 46.0, draw_h: 46.0,
                faces_left: false,
                idle:   AnimClip(row: 0, first_col: 0, frames: 4, fps: 5.0),
                attack: AnimClip(row: 4, first_col: 0, frames: 3, fps: 9.0),
            ),
            overworld: Some(OverworldWalk(
                texture: "club_goblin",
                frame_w: 16, frame_h: 16,
                draw_w: 20.0, draw_h: 20.0,
                row_down: 0, row_up: 1, row_right: 2, row_left: 3,
                frames: 4, fps: 8.0,
            )),
            skills: ["club_smash"],
            ai: Random,
            xp: 22,
            gold: 16,
            drops: [ItemDrop(item: "potion", chance: 0.22)],
        ),
        // ARCHER GOBLIN: the goblins' skirmisher — a glass cannon that looses a
        // piercing ARROW SHOT from range (its Random AI mixes the shot with plain
        // swings). Thin on HP and defense, so it folds fast once you reach it.
        EnemyDef(
            id: "archer_goblin",
            name: "ARCHER GOBLIN",
            stats: Stats(max_hp: 46, max_mp: 0, attack: 20, defense: 9, magic: 0, speed: 16),
            sprite: BattlerSprite(
                texture: "archer_goblin",
                frame_w: 16, frame_h: 16,
                draw_w: 46.0, draw_h: 46.0,
                faces_left: false,
                idle:   AnimClip(row: 0, first_col: 0, frames: 4, fps: 5.0),
                attack: AnimClip(row: 4, first_col: 0, frames: 3, fps: 8.0),
            ),
            overworld: Some(OverworldWalk(
                texture: "archer_goblin",
                frame_w: 16, frame_h: 16,
                draw_w: 20.0, draw_h: 20.0,
                row_down: 0, row_up: 1, row_right: 2, row_left: 3,
                frames: 4, fps: 8.0,
            )),
            skills: ["arrow_shot"],
            ai: Random,
            xp: 24,
            gold: 18,
            drops: [ItemDrop(item: "potion", chance: 0.20)],
        ),
        // ORC BRUTE: the prisoners the underworld twisted into hulking beasts.
        // A slow, heavy wall of muscle — high HP and a punishing BRUTE SLAM — that
        // lumbers after you on the map (easy to sidestep, like a gargoyle). Some
        // were freed only under heavy guard; here in the depths there is no guard.
        EnemyDef(
            id: "orc_brute",
            name: "ORC BRUTE",
            stats: Stats(max_hp: 150, max_mp: 0, attack: 34, defense: 19, magic: 0, speed: 9),
            sprite: BattlerSprite(
                texture: "orc_brute",
                frame_w: 16, frame_h: 16,
                draw_w: 58.0, draw_h: 58.0,
                faces_left: false,
                idle:   AnimClip(row: 0, first_col: 0, frames: 4, fps: 3.0),
                attack: AnimClip(row: 4, first_col: 0, frames: 5, fps: 9.0),
            ),
            overworld: Some(OverworldWalk(
                texture: "orc_brute",
                frame_w: 16, frame_h: 16,
                draw_w: 24.0, draw_h: 24.0,
                row_down: 0, row_up: 1, row_right: 2, row_left: 3,
                frames: 5, fps: 6.0,
            )),
            skills: ["brute_slam"],
            ai: Random,
            xp: 48,
            gold: 40,
            // Hulking and ponderous — far slower than the player.
            overworld_speed: Some(22.0),
            drops: [
                ItemDrop(item: "might_tonic", chance: 0.18),
                ItemDrop(item: "hi_potion",   chance: 0.12),
            ],
        ),
        // ------ Future foes: defined and reachable via the dev fight menu, but
        // not yet placed in any level's spawns. ------
        // The DEMON ELITE: a demon in war-plate — orc-like brawn bolted onto the
        // demon's fire. Same abilities as a demon (FIREBALL + CLAW) but far tougher
        // and harder-hitting. demon_elite.png is the demon's own 6x8 sheet redrawn
        // in armor, so the frame layout is copied from the demon verbatim.
        EnemyDef(
            id: "demon_elite",
            name: "DEMON ELITE",
            stats: Stats(max_hp: 140, max_mp: 34, attack: 30, defense: 14, magic: 18, speed: 11),
            sprite: BattlerSprite(
                texture: "demon_elite",
                frame_w: 16, frame_h: 16,
                draw_w: 58.0, draw_h: 58.0,
                faces_left: false,
                idle:   AnimClip(row: 0, first_col: 0, frames: 4, fps: 4.0),
                attack: AnimClip(row: 4, first_col: 0, frames: 4, fps: 10.0),
            ),
            overworld: Some(OverworldWalk(
                texture: "demon_elite",
                frame_w: 16, frame_h: 16,
                draw_w: 22.0, draw_h: 22.0,
                row_down: 0, row_up: 1, row_right: 2, row_left: 3,
                frames: 5, fps: 8.0,
            )),
            skills: ["fireball", "claw"],
            ai: Random,
            xp: 40,
            gold: 34,
            drops: [
                ItemDrop(item: "might_tonic", chance: 0.18),
                ItemDrop(item: "hi_potion",   chance: 0.12),
            ],
        ),
        // The MINOTAUR: a lumbering miniboss that lowers its horns to GORING CHARGE
        // a lone hero (a screen-wrapping charge), TRAMPLES the whole party, and
        // hurls a FIREBALL. Fought in a `boss`-flagged encounter so it plays the
        // boss theme. minotaur.png is the demon's sheet with the walk-LEFT row
        // removed, so it's 6x7: rows 0-2 walk down/up/right, rows 3-6 the attack
        // poses (all shifted up one from the demon's 4-7). With no left-walk row,
        // the overworld map reuses the right-walk row for leftward movement.
        EnemyDef(
            id: "minotaur",
            name: "MINOTAUR",
            stats: Stats(max_hp: 240, max_mp: 50, attack: 30, defense: 18, magic: 20, speed: 10),
            sprite: BattlerSprite(
                texture: "minotaur",
                frame_w: 16, frame_h: 16,
                draw_w: 72.0, draw_h: 72.0,
                faces_left: false,
                idle:   AnimClip(row: 0, first_col: 0, frames: 4, fps: 3.0),
                attack: AnimClip(row: 3, first_col: 0, frames: 4, fps: 9.0),
            ),
            overworld: Some(OverworldWalk(
                texture: "minotaur",
                frame_w: 16, frame_h: 16,
                // No walk-LEFT row on this sheet, so left reuses the right-walk row.
                // The walk rows are 4 frames (not the demon's 5).
                draw_w: 26.0, draw_h: 26.0,
                row_down: 0, row_up: 1, row_right: 2, row_left: 2,
                frames: 4, fps: 6.0,
            )),
            skills: ["goring_charge", "trample", "fireball"],
            ai: Random,
            xp: 90,
            gold: 70,
            // Hulking and ponderous — far slower than the player on the map.
            overworld_speed: Some(24.0),
            drops: [
                ItemDrop(item: "might_tonic", chance: 0.25),
                ItemDrop(item: "hi_potion",   chance: 0.20),
            ],
        ),
        // ------ TOOL enemies: inert engines worked by the foes beside them ------
        // BALLISTA: a siege engine wheeled into the passes of TRAVELLER'S END and
        // the CHARRED DEPTHS. It never acts on its own; an aware foe spends a turn
        // to crank and loose a heavy BOLT (fired from the ballista, so its own high
        // attack drives the damage). Tanky enough to weather direct fire — but once
        // the last enemy working it falls, it has no crew and crumbles on its own.
        // Never leads an encounter (it has no overworld sprite); place it *after*
        // its crew so the roaming map sprite stays that of a real foe.
        // ballista.png is one row of 16x16 frames: attack cols 0-2 (the loose),
        // then idle cols 3-6.
        EnemyDef(
            id: "ballista",
            name: "BALLISTA",
            stats: Stats(max_hp: 160, max_mp: 0, attack: 24, defense: 18, magic: 0, speed: 3),
            sprite: BattlerSprite(
                texture: "ballista",
                frame_w: 16, frame_h: 16,
                draw_w: 52.0, draw_h: 52.0,
                faces_left: false,
                idle:   AnimClip(row: 0, first_col: 3, frames: 4, fps: 3.0),
                attack: AnimClip(row: 0, first_col: 0, frames: 3, fps: 6.0),
            ),
            ai: Basic,
            xp: 30,
            gold: 22,
            drops: [ItemDrop(item: "hi_potion", chance: 0.20)],
            // The tool behaviour: aware foes strongly prefer to work the engine,
            // loosing its BOLT on most of their turns while it stands (they only
            // fall back to their own attacks now and then).
            tool: Some(ToolDef(skill: "ballista_bolt", operate_chance: 0.8)),
        ),
        // ------ CLONE enemies: shadow-mirrors of the party ---------------------
        // A dark double of each hero — identical stats, sprite, gear, and full
        // skill set, to the number, but sworn to the other side. Each borrows its
        // hero's own battle sheet under a shadowy violet tint, so a mirror reads
        // apart from the real hero across the field. Straight stat-clones — plain
        // Random-AI foes, no special engine behaviour. Unused in any level for now:
        // they meet the party only in the `mirror_match` boss encounter, all three
        // at once. (Their stats/gear must be kept in step with the party defs above
        // — see the `clones_mirror_the_party` test in tests/data.rs.)
        EnemyDef(
            id: "clone_roland",
            name: "DARK ROLAND",
            // ROLAND's stats and gear, to the number.
            stats: Stats(max_hp: 120, max_mp: 24, attack: 22, defense: 14, magic: 10, speed: 12),
            sprite: BattlerSprite(
                texture: "swordsman",
                frame_w: 16, frame_h: 16,
                draw_w: 48.0, draw_h: 48.0,
                faces_left: false,
                tint: Some((150, 120, 190)),   // a shadow cast over the hero's sheet
                idle:   AnimClip(row: 2, first_col: 0, frames: 4, fps: 5.0),
                attack: AnimClip(row: 6, first_col: 0, frames: 4, fps: 14.0),
            ),
            // Everything ROLAND can learn: POWER STRIKE, WHIRLWIND, SUNDER.
            skills: ["power_strike", "whirlwind", "sunder"],
            weapon: Some("iron_sword"),
            armor: Some("leather_armor"),
            ai: Random,
            xp: 70,
            gold: 55,
            drops: [ItemDrop(item: "hi_potion", chance: 0.30)],
        ),
        EnemyDef(
            id: "clone_elara",
            name: "DARK ELARA",
            stats: Stats(max_hp: 78, max_mp: 60, attack: 10, defense: 9, magic: 26, speed: 13),
            sprite: BattlerSprite(
                texture: "mage",
                frame_w: 16, frame_h: 16,
                draw_w: 48.0, draw_h: 48.0,
                faces_left: false,
                tint: Some((150, 120, 190)),
                idle:   AnimClip(row: 2, first_col: 0, frames: 4, fps: 5.0),
                attack: AnimClip(row: 7, first_col: 0, frames: 5, fps: 14.0),
            ),
            // Everything ELARA can learn: FIREBOLT, FROST, and MEND — so she mends
            // her fellow clones. Cut her down first.
            skills: ["firebolt", "frost", "mend"],
            armor: Some("travelers_robe"),
            ai: Random,
            xp: 68,
            gold: 55,
            drops: [ItemDrop(item: "ether", chance: 0.30)],
        ),
        EnemyDef(
            id: "clone_gareth",
            name: "DARK GARETH",
            stats: Stats(max_hp: 94, max_mp: 30, attack: 20, defense: 11, magic: 8, speed: 21),
            sprite: BattlerSprite(
                texture: "hermit",
                frame_w: 16, frame_h: 16,
                draw_w: 48.0, draw_h: 48.0,
                faces_left: false,
                tint: Some((150, 120, 190)),
                idle:   AnimClip(row: 2, first_col: 0, frames: 5, fps: 5.0),
                attack: AnimClip(row: 6, first_col: 0, frames: 6, fps: 18.0),
            ),
            // Everything GARETH can learn: QUICK SLASH, SWALLOW CUT, FINAL CUT. The
            // fastest clone by far — it acts first.
            skills: ["quick_slash", "swallow_cut", "final_cut"],
            weapon: Some("scouts_edge"),
            armor: Some("scouts_cloak"),
            ai: Random,
            xp: 68,
            gold: 55,
            drops: [ItemDrop(item: "hi_potion", chance: 0.30)],
        ),
    ],

    skills: [
        SkillDef(
            id: "power_strike", name: "POWER STRIKE",
            description: "A focused two-handed blow to one foe.",
            mp_cost: 4, power: 175, kind: Physical, target: OneEnemy,
        ),
        SkillDef(
            id: "whirlwind", name: "WHIRLWIND",
            description: "A spinning slash that hits every foe.",
            mp_cost: 8, power: 95, kind: Physical, target: AllEnemies,
        ),
        // ROLAND's capstone (his last learned move, replacing the shared MEND):
        // a devastating single-target cleave, mightier than POWER STRIKE.
        SkillDef(
            id: "sunder", name: "SUNDER",
            description: "A crushing overhead cleave that splits a foe's guard.",
            mp_cost: 12, power: 245, kind: Physical, target: OneEnemy,
        ),
        // ELARA's capstone: a potent restorative mastered late (her last learned
        // move). Only she knows it — the other heroes get their own ultimate below.
        SkillDef(
            id: "mend", name: "MEND",
            description: "Mastered white magic: heals an ally, or revives a fallen one.",
            mp_cost: 10, power: 240, kind: Heal, target: OneAlly,
            revives: true,   // can bring a downed ally back
        ),
        SkillDef(
            id: "claw", name: "CLAW",
            description: "A raking swipe of the demon's claws.",
            mp_cost: 0, power: 125, kind: Physical, target: OneEnemy,
        ),
        SkillDef(
            id: "fireball", name: "FIREBALL",
            description: "A demon's blazing orb; leaves the target burning.",
            mp_cost: 6, power: 150, kind: Magical, target: OneEnemy,
            inflicts: ["burn"], unblockable: true,
            anim: Projectile(texture: "fireball"),   // hurls a fireball at the target
        ),
        SkillDef(
            id: "firebolt", name: "FIREBOLT",
            description: "Hurl a searing bolt of flame at one foe.",
            mp_cost: 6, power: 180, kind: Magical, target: OneEnemy,
            unblockable: true,
            anim: Projectile(texture: "fireball"),   // ELARA's flaming bolt
        ),
        SkillDef(
            id: "frost", name: "FROST",
            description: "A biting frost that chills all foes.",
            mp_cost: 12, power: 115, kind: Magical, target: AllEnemies,
            unblockable: true,
        ),
        SkillDef(
            id: "flame_breath", name: "FLAME BREATH",
            description: "A dragon's roaring gout of fire; sears and burns every foe.",
            mp_cost: 10, power: 135, kind: Magical, target: AllEnemies,
            inflicts: ["burn"], unblockable: true,
            // Fans a fireball out at every party member at once.
            anim: Projectile(texture: "fireball"),
        ),
        SkillDef(
            id: "tail_swipe", name: "TAIL SWIPE",
            description: "A crushing sweep of the dragon's tail.",
            mp_cost: 0, power: 160, kind: Physical, target: OneEnemy,
        ),
        // TRAVELLER'S END foes.
        SkillDef(
            id: "reap", name: "REAP",
            description: "A skeleton's rusted blade drags across one foe.",
            mp_cost: 0, power: 135, kind: Physical, target: OneEnemy,
        ),
        SkillDef(
            id: "lance_charge", name: "LANCE CHARGE",
            description: "A thundering couched-lance charge at one hero.",
            mp_cost: 6, power: 145, kind: Physical, target: OneEnemy,
            unblockable: true,
            anim: Charge,   // gallops through the hero and wraps the field
        ),
        // The warhorse's stomp is a heavy but telegraphed blow — you can brace and
        // block it, unlike the piercing LANCE CHARGE. That gives the party timing
        // counterplay against a knight pack (whose other threats are unblockable).
        SkillDef(
            id: "trample", name: "TRAMPLE",
            description: "The warhorse tramples the whole party underhoof.",
            mp_cost: 8, power: 90, kind: Physical, target: AllEnemies,
            anim: Charge,   // sweeps across the whole party
        ),
        // The MINOTAUR's signature: horns down, it barrels through one hero and
        // off the far edge, wrapping the field back to its post. Piercing, so it
        // can't be timed-blocked.
        SkillDef(
            id: "goring_charge", name: "GORING CHARGE",
            description: "The minotaur gores a hero, charging clean through.",
            mp_cost: 6, power: 150, kind: Physical, target: OneEnemy,
            unblockable: true,
            anim: Charge,
        ),
        // GARETH's blade-work. Fast and cheap, to match the nimblest hero: a
        // spammable single strike and a darting sweep across a whole pack.
        SkillDef(
            id: "quick_slash", name: "QUICK SLASH",
            description: "A darting cut, drawn and returned in a blink.",
            mp_cost: 3, power: 150, kind: Physical, target: OneEnemy,
        ),
        SkillDef(
            id: "swallow_cut", name: "SWALLOW CUT",
            description: "A flowing sweep that flits between every foe.",
            mp_cost: 7, power: 95, kind: Physical, target: AllEnemies,
            anim: Charge,   // GARETH darts across the whole enemy line
        ),
        // GARETH's capstone (his last learned move, replacing the shared MEND): a
        // single, flawless killing stroke — the deadliest hit in the party.
        SkillDef(
            id: "final_cut", name: "FINAL CUT",
            description: "A flawless killing stroke that finds the fatal gap.",
            mp_cost: 10, power: 250, kind: Physical, target: OneEnemy,
        ),
        // ------ UNDERWORLD: the goblin and orc families ---------------------
        // The club goblins' crude but heavy swing. Free, so they lean on it.
        SkillDef(
            id: "club_smash", name: "CLUB SMASH",
            description: "A goblin's crude club brought down on one foe.",
            mp_cost: 0, power: 130, kind: Physical, target: OneEnemy,
        ),
        // The archer goblins' shot: a piercing arrow that flies to its mark and
        // ignores a timed block (as with every ranged/piercing blow).
        SkillDef(
            id: "arrow_shot", name: "ARROW SHOT",
            description: "A goblin's loosed arrow strikes one foe from afar.",
            mp_cost: 0, power: 120, kind: Physical, target: OneEnemy,
            unblockable: true,
            anim: Projectile(texture: "arrow"),   // looses an arrow at the target
        ),
        // The orc brutes' hammering overhead — slow to wind up, brutal to land.
        SkillDef(
            id: "brute_slam", name: "BRUTE SLAM",
            description: "A hulking orc's two-fisted slam crashes down on one foe.",
            mp_cost: 0, power: 170, kind: Physical, target: OneEnemy,
        ),
        // The BALLISTA's shot: a heavy bolt loosed from the siege engine when an
        // aware foe works it. It hits hard, but a hero can still read the shot and
        // time a block — the counterplay to a weapon you can also just destroy.
        SkillDef(
            id: "ballista_bolt", name: "BOLT",
            description: "A heavy siege bolt loosed at one foe. It hits hard.",
            mp_cost: 0, power: 200, kind: Physical, target: OneEnemy,
            anim: Projectile(texture: "bolt"),   // looses a bolt at the target
        ),
    ],

    // ------------------------------------------------------------------------
    // Status effects. This list is the extension point for conditions: a new
    // one is a pure data entry so long as it can be expressed with the fields
    // below (see StatusDef in src/data.rs). A status drains or restores HP each
    // round (`damage_per_turn`; negative heals) and/or shifts the afflicted
    // battler's stats while it lasts (`stat_mods`, e.g. a SLOW with speed: -6).
    // Skills apply them via their `inflicts` list. Ticks resolve at the end of
    // each round; the status counts down and clears on its own.
    //
    // To add e.g. POISON or REGEN, just append an entry here and reference it
    // from a skill's `inflicts` — no engine change. A genuinely new *mechanic*
    // (like "skip a turn") is one new optional field here plus its apply site.
    // ------------------------------------------------------------------------
    statuses: [
        StatusDef(
            id: "burn", name: "BURN",
            duration: 3, damage_per_turn: 8,
            tint: Some((255, 140, 60)),
        ),
        // Buff statuses granted by consumable items (a stat_mods shift for a few
        // rounds). These are how items "change stats" / "defend" — see the items
        // section below, and ItemEffect::inflicts in src/data.rs.
        StatusDef(
            id: "might", name: "MIGHT",
            duration: 3,
            stat_mods: StatMods(attack: 8),
            tint: Some((255, 120, 120)),
        ),
        StatusDef(
            id: "guard", name: "GUARD",
            duration: 3,
            stat_mods: StatMods(defense: 8),
            tint: Some((140, 200, 255)),
        ),
    ],

    // ------------------------------------------------------------------------
    // Equipment. Weapons raise attack/magic and add crit/accuracy; armor raises
    // defense and adds evasion (the chance to dodge a hit entirely). Every item
    // carries a description. Characters/enemies equip them by id via their
    // `weapon` / `armor` fields. Icons are 16x16 (register keys in src/data.rs).
    // ------------------------------------------------------------------------
    equipment: [
        EquipmentDef(
            id: "iron_sword", name: "IRON SWORD",
            description: "Standard-issue soldier's blade.",
            slot: Weapon, icon: "starter_sword",
            mods: StatMods(attack: 6), crit: 6, accuracy: 4,
        ),
        EquipmentDef(
            id: "leather_armor", name: "LEATHER ARMOR",
            description: "Boiled leather; turns a glance.",
            slot: Armor, icon: "starter_gear",
            mods: StatMods(defense: 5), evasion: 4,
        ),
        EquipmentDef(
            id: "travelers_robe", name: "TRAVELER'S ROBE",
            description: "Light, enchanted travel cloth.",
            slot: Armor, icon: "starter_gear",
            mods: StatMods(defense: 3, magic: 2), evasion: 8,
        ),
        // A gargoyle's fists: brutal power, but so clumsy they whiff constantly
        // (the accuracy penalty is what makes gargoyles "prone to missing").
        EquipmentDef(
            id: "stone_fists", name: "STONE FISTS",
            description: "Crushing stone knuckles; heavy and clumsy.",
            slot: Weapon, icon: "starter_sword",
            mods: StatMods(attack: 18), crit: 12, accuracy: -34,
        ),
        // A dark knight's warlance: long reach, a keen point that finds the gap.
        EquipmentDef(
            id: "cavalry_lance", name: "CAVALRY LANCE",
            description: "A mounted knight's warlance; long and deadly.",
            slot: Weapon, icon: "starter_sword",
            mods: StatMods(attack: 10), crit: 8, accuracy: 6,
        ),
        // GARETH's kit: a scout's gear, light and quick. The back-slung blade is
        // keen and fast (a touch of speed, high crit/accuracy); the cloak trades
        // armor for the evasion of a man who lived by not being caught.
        EquipmentDef(
            id: "scouts_edge", name: "SCOUT'S EDGE",
            description: "A keen, light back-slung blade.",
            slot: Weapon, icon: "starter_sword",
            mods: StatMods(attack: 7, speed: 3), crit: 14, accuracy: 10,
        ),
        EquipmentDef(
            id: "scouts_cloak", name: "SCOUT'S CLOAK",
            description: "A light, silent ranger's cloak.",
            slot: Armor, icon: "starter_gear",
            mods: StatMods(defense: 3, speed: 2), evasion: 14,
        ),
    ],

    // ------------------------------------------------------------------------
    // Consumable items. Unlike equipment they are spent, not worn: bought at
    // shops, dropped by enemies (see an enemy's `drops:`), and used in battle
    // from the ITEM command (restorative ones can also be used from a rest).
    // `target` says who it hits; `effect` is a composable bag — heal, damage,
    // restore_mp, and/or inflict statuses (that last is how an item changes
    // stats / "defends"). Icons default to the shared `item_bag` pouch. Adding
    // an item is pure data — no engine change. (See src/data.rs ItemDef.)
    // ------------------------------------------------------------------------
    items: [
        ItemDef(
            id: "potion", name: "POTION",
            description: "A herbal draught. Restores 40 HP.",
            price: 30, target: OneAlly,
            effect: ItemEffect(heal: 40),
        ),
        ItemDef(
            id: "hi_potion", name: "HI-POTION",
            description: "A potent tonic. Restores 100 HP.",
            price: 90, target: OneAlly,
            effect: ItemEffect(heal: 100),
        ),
        ItemDef(
            id: "ether", name: "ETHER",
            description: "Bitter blue brew. Restores 20 MP.",
            price: 60, target: OneAlly,
            effect: ItemEffect(restore_mp: 20),
        ),
        ItemDef(
            id: "bomb", name: "BOMB",
            description: "A lit satchel charge. 35 fire damage to a foe.",
            price: 40, target: OneEnemy,
            effect: ItemEffect(damage: 35, inflicts: ["burn"]),
        ),
        ItemDef(
            id: "might_tonic", name: "MIGHT TONIC",
            description: "Steels the blood. Raises ATTACK for a few rounds.",
            price: 50, target: OneAlly,
            effect: ItemEffect(inflicts: ["might"]),
        ),
        ItemDef(
            id: "guard_salve", name: "GUARD SALVE",
            description: "A hardening balm. Raises DEFENSE for a few rounds.",
            price: 50, target: OneAlly,
            effect: ItemEffect(inflicts: ["guard"]),
        ),
    ],

    // ------------------------------------------------------------------------
    // Shops. Each is a little interior you enter from a keeper standing on an
    // overworld screen (see a screen's `shops:` list). `facing` is the wall the
    // keeper looks at — and the doorway you leave by. `stock` items are ids into
    // `equipment` above; buying deducts `price` gold and equips to a chosen
    // party member. Adding a shop is pure data — no engine change.
    // ------------------------------------------------------------------------
    shops: [
        ShopDef(
            id: "greenwood_outfitter",
            name: "OUTFITTER",
            greeting: Some("FRESH FROM THE FORGE - WHAT'LL IT BE?"),
            facing: Down,
            stock: [
                ShopStock(item: "iron_sword",     price: 40),
                ShopStock(item: "leather_armor",  price: 40),
                ShopStock(item: "travelers_robe", price: 70),
                ShopStock(item: "stone_fists",    price: 120),
                // Consumables sit on the same counter — `stock` resolves an id as
                // equipment first, then as an item, so a shop can sell either.
                ShopStock(item: "potion",         price: 30),
                ShopStock(item: "ether",          price: 60),
                ShopStock(item: "bomb",           price: 40),
                ShopStock(item: "might_tonic",    price: 50),
            ],
        ),
    ],

    encounters: [
        // Slime swarms — three to a fight — fill the GREENWOOD.
        EncounterDef(id: "slime_trio", enemies: ["slime", "slime", "slime"]),
        // Mimics — late-game ambushers sprung from a disguised chest. A lone one
        // is trouble enough; the CHARRED DEPTHS field them in pairs.
        EncounterDef(id: "mimic_solo", enemies: ["mimic"]),
        EncounterDef(id: "mimic_pair", enemies: ["mimic", "mimic"]),
        // Gargoyle patrols hold STONE PASS.
        EncounterDef(id: "gargoyle_solo", enemies: ["gargoyle"]),
        EncounterDef(id: "gargoyle_duo",  enemies: ["gargoyle", "gargoyle"]),
        // Demons: the lone GREENWOOD guardian, and the packs in the DEMON FORTRESS.
        EncounterDef(id: "demon_solo", enemies: ["demon"]),
        EncounterDef(id: "demon_duo",  enemies: ["demon", "demon"]),
        EncounterDef(id: "demon_trio", enemies: ["demon", "demon", "demon"]),
        // The DRAGON boss at the heart of the DEMON FORTRESS. Flagged `boss` so
        // the fight plays the boss theme instead of the usual battle track.
        EncounterDef(id: "dragon_boss", enemies: ["dragon"], boss: true),
        // TRAVELLER'S END — a long climb of escalating packs. Crabs and skeletons
        // on the low slopes; gargoyle patrols on the shelves; dark knights and
        // stray demons holding the summit.
        EncounterDef(id: "crab_pair",         enemies: ["mountain_crab", "mountain_crab"]),
        EncounterDef(id: "crab_trio",         enemies: ["mountain_crab", "mountain_crab", "mountain_crab"]),
        EncounterDef(id: "skeleton_duo",      enemies: ["skeleton", "skeleton"]),
        EncounterDef(id: "skeleton_trio",     enemies: ["skeleton", "skeleton", "skeleton"]),
        EncounterDef(id: "knight_solo",       enemies: ["dark_knight"]),
        EncounterDef(id: "knight_duo",        enemies: ["dark_knight", "dark_knight"]),
        EncounterDef(id: "knight_skeletons",  enemies: ["dark_knight", "skeleton", "skeleton"]),
        EncounterDef(id: "knight_demon",      enemies: ["dark_knight", "demon"]),
        EncounterDef(id: "knight_guard",      enemies: ["dark_knight", "dark_knight", "skeleton"]),
        // A ballista dug in on the shelves, its crew loosing bolts down the pass.
        // Fell the crew (or the engine) to stop the fire; abandoned, it crumbles.
        EncounterDef(id: "ballista_nest",     enemies: ["dark_knight", "skeleton", "ballista"]),
        EncounterDef(id: "ballista_crew",     enemies: ["skeleton", "skeleton", "ballista"]),
        // UNDERWORLD — the CHARRED DEPTHS. Goblin packs (clubbers screening their
        // archers) fill the upper halls; orc brutes anchor the deeper chambers,
        // and the demons that dragged the prisoners down still hold the depths.
        EncounterDef(id: "goblin_pair",   enemies: ["club_goblin", "archer_goblin"]),
        EncounterDef(id: "goblin_pack",   enemies: ["club_goblin", "club_goblin", "archer_goblin"]),
        EncounterDef(id: "archer_duo",    enemies: ["archer_goblin", "archer_goblin"]),
        EncounterDef(id: "orc_solo",      enemies: ["orc_brute"]),
        EncounterDef(id: "orc_goblins",   enemies: ["orc_brute", "club_goblin", "archer_goblin"]),
        EncounterDef(id: "orc_duo",       enemies: ["orc_brute", "orc_brute"]),
        // The deep chambers: walls of orc muscle and demon-led warbands.
        EncounterDef(id: "orc_trio",      enemies: ["orc_brute", "orc_brute", "orc_brute"]),
        EncounterDef(id: "demon_orc",     enemies: ["demon", "orc_brute"]),
        EncounterDef(id: "demon_orcs",    enemies: ["demon", "orc_brute", "club_goblin"]),
        // The depths' last guard: a demon flanked by two remade orc thralls.
        EncounterDef(id: "demon_guard",   enemies: ["demon", "orc_brute", "orc_brute"]),
        // A ballista emplacement in the deep halls, goblins and an orc working it.
        EncounterDef(id: "ballista_battery", enemies: ["orc_brute", "archer_goblin", "ballista"]),
        EncounterDef(id: "ballista_pit",     enemies: ["club_goblin", "archer_goblin", "ballista"]),
        // Future foes, not yet placed in a level — reachable now via the dev fight
        // menu. The MINOTAUR is `boss`-flagged so it plays the boss theme.
        EncounterDef(id: "demon_elite_solo", enemies: ["demon_elite"]),
        EncounterDef(id: "minotaur_boss",    enemies: ["minotaur"], boss: true),
        // The MIRROR MATCH — a dark double of each hero, all three at once. A `boss`
        // fight (plays the boss theme). Not placed in any level yet; reachable via
        // the dev fight menu.
        EncounterDef(id: "mirror_match", enemies: ["clone_roland", "clone_elara", "clone_gareth"], boss: true),
    ],

    // ------------------------------------------------------------------------
    // Levels. Each has a marker on the map screen and a set of connected
    // screens (rooms). Tile legend (see src/overworld.rs):
    //   '.' grass (walkable)   'T' tree    'R' rock
    //   '~' water              '#' barricade   (all non-grass tiles are solid)
    // Screen neighbour fields (north/south/east/west) index this level's
    // screens; walk into a mid-edge opening to flip to that screen.
    // ------------------------------------------------------------------------
    levels: [
        // GREENWOOD — a straightforward forest walk with some winding parts,
        // flowing east then bending north into the deep wood.
        LevelDef(
            id: "greenwood", name: "GREENWOOD",
