                    ],
                    // A real prize — a CAVALRY LANCE — flanked by a nest of mimics.
                    // The deepest hall's treasure is the best-guarded, and the most
                    // likely to bite: this "chest" is two mimics at once.
                    chests: [
                        ChestSpawn(col: 16, row: 1, gold: 140, equipment: Some("cavalry_lance")),
